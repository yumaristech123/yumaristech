rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userColl, userId) {
      return get(/databases/$(database)/documents/$(userColl)/$(userId)).data;
    }

    function isGuru(userColl) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/$(userColl)/$(request.auth.uid)) && 
             getUserData(userColl, request.auth.uid).role == 'guru';
    }

    function isAdmin(userColl) {
      return isSignedIn() && (
        (request.auth.token.email == "yumaristech@gmail.com" && isEmailVerified()) ||
        (exists(/databases/$(database)/documents/$(userColl)/$(request.auth.uid)) && getUserData(userColl, request.auth.uid).role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'role', 'xp', 'completedModules']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['siswa', 'guru', 'admin'] &&
             data.xp is number && data.xp >= 0 &&
             data.completedModules is list && data.completedModules.size() <= 1000 &&
             (!('kelas' in data) || data.kelas is string) &&
             (!('password' in data) || data.password is string) &&
             (!('stars' in data) || data.stars is number);
    }

    function isValidQuizResult(data) {
      return data.keys().hasAll(['moduleId', 'userId', 'score', 'timestamp']) &&
             data.moduleId is string && data.moduleId.size() <= 100 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.score is number && data.score >= 0 && data.score <= 1000 && 
             data.timestamp is number;
    }

    function isValidClass(data) {
      return data.keys().hasAll(['id', 'name']) &&
             data.id is string && data.id.size() <= 50 &&
             data.name is string && data.name.size() <= 50;
    }

    // --- Mathematics Course ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if (isOwner(userId) || isAdmin('users')) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin('users')) && 
                    isValidUser(request.resource.data) &&
                    (
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['xp', 'completedModules'])) ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasAny(['displayName', 'kelas', 'role', 'password', 'email', 'stars'])) ||
                      isAdmin('users')
                    );
      allow delete: if isAdmin('users');
    }

    match /quiz_results/{resultId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidQuizResult(request.resource.data);
      allow update: if isAdmin('users');
      allow delete: if isAdmin('users') || isGuru('users');
    }

    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin('users') && isValidClass(request.resource.data);
      allow delete: if isAdmin('users');
    }

    // --- English Course ---

    match /users_en/{userId} {
      allow read: if isSignedIn();
      allow create: if (isOwner(userId) || isAdmin('users_en')) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin('users_en')) && 
                    isValidUser(request.resource.data) &&
                    (
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['xp', 'completedModules'])) ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasAny(['displayName', 'kelas', 'role', 'password', 'email', 'stars'])) ||
                      isAdmin('users_en')
                    );
      allow delete: if isAdmin('users_en');
    }

    match /quiz_results_en/{resultId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidQuizResult(request.resource.data);
      allow update: if isAdmin('users_en');
      allow delete: if isAdmin('users_en') || isGuru('users_en');
    }

    match /classes_en/{classId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin('users_en') && isValidClass(request.resource.data);
      allow delete: if isAdmin('users_en');
    }

    // --- Kedinasan Course ---

    match /users_kd/{userId} {
      allow read: if isSignedIn();
      allow create: if (isOwner(userId) || isAdmin('users_kd')) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin('users_kd')) && 
                    isValidUser(request.resource.data) &&
                    (
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['xp', 'completedModules'])) ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasAny(['displayName', 'kelas', 'role', 'password', 'email', 'stars'])) ||
                      isAdmin('users_kd')
                    );
      allow delete: if isAdmin('users_kd');
    }

    match /quiz_results_kd/{resultId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidQuizResult(request.resource.data);
      allow update: if isAdmin('users_kd');
      allow delete: if isAdmin('users_kd') || isGuru('users_kd');
    }

    match /classes_kd/{classId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin('users_kd') && isValidClass(request.resource.data);
      allow delete: if isAdmin('users_kd');
    }

    // --- UTBK SNBT Course ---

    match /users_utbk/{userId} {
      allow read: if isSignedIn();
      allow create: if (isOwner(userId) || isAdmin('users_utbk')) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin('users_utbk')) && 
                    isValidUser(request.resource.data) &&
                    (
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['xp', 'completedModules'])) ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasAny(['displayName', 'kelas', 'role', 'password', 'email', 'stars'])) ||
                      isAdmin('users_utbk')
                    );
      allow delete: if isAdmin('users_utbk');
    }

    match /quiz_results_utbk/{resultId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidQuizResult(request.resource.data);
      allow update: if isAdmin('users_utbk');
      allow delete: if isAdmin('users_utbk') || isGuru('users_utbk');
    }

    match /classes_utbk/{classId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin('users_utbk') && isValidClass(request.resource.data);
      allow delete: if isAdmin('users_utbk');
    }

    // --- TKA Course ---

    match /users_tka/{userId} {
      allow read: if isSignedIn();
      allow create: if (isOwner(userId) || isAdmin('users_tka')) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin('users_tka')) && 
                    isValidUser(request.resource.data) &&
                    (
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['xp', 'completedModules'])) ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasAny(['displayName', 'kelas', 'role', 'password', 'email', 'stars'])) ||
                      isAdmin('users_tka')
                    );
      allow delete: if isAdmin('users_tka');
    }

    match /quiz_results_tka/{resultId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidQuizResult(request.resource.data);
      allow update: if isAdmin('users_tka');
      allow delete: if isAdmin('users_tka') || isGuru('users_tka');
    }

    match /classes_tka/{classId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin('users_tka') && isValidClass(request.resource.data);
      allow delete: if isAdmin('users_tka');
    }
  }
}
