rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'xp', 'role']) &&
             data.uid is string &&
             data.xp is number &&
             data.xp >= 0 &&
             data.role in ['siswa', 'guru', 'admin'];
    }

    function isValidQuizResult(data) {
      return data.keys().hasAll(['moduleId', 'userId', 'score', 'timestamp']) &&
             data.moduleId is string &&
             data.userId is string &&
             data.score is number &&
             data.score >= 0 &&
             data.timestamp is number;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "yumaristech@gmail.com" && request.auth.token.email_verified == true));
    }

    // Rules for Users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
    }

    // Rules for Quiz Results
    match /quiz_results/{resultId} {
      allow read: if isAuthenticated(); // Or restrict to internal admin if needed
      allow create: if isAuthenticated() && 
                   request.resource.data.userId == request.auth.uid && 
                   isValidQuizResult(request.resource.data);
    }
  }
}
